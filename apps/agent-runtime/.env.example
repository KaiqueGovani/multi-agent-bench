# ---- LLM configuration ----
# Set ENABLE_LIVE_LLM=true to use real Bedrock inference.
# When false, each architecture returns a fixed mock response.
ENABLE_LIVE_LLM=false

# Required when ENABLE_LIVE_LLM=true.
# Generate a bearer token in the AWS Console (Bedrock > API Keys).
# boto3 will pick this up automatically via the environment.
AWS_BEARER_TOKEN_BEDROCK=

# Model id used by Strands BedrockModel. Pick any text-capable model you
# have access to. Examples:
#   us.anthropic.claude-haiku-4-5-20251001-v1:0
#   anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0

# AWS region where your Bedrock access is configured.
AWS_REGION=us-east-1

# ---- Application ----
APP_ENV=local
APP_NAME=Multi-Agent Bench Agent Runtime
APP_VERSION=0.1.0
LOG_LEVEL=INFO

# ---- Architecture ----
DEFAULT_ARCHITECTURE_MODE=centralized_orchestration
DEFAULT_REVIEW_POLICY_VERSION=strands-review-v1
RUNTIME_MAX_HANDOFFS=6
RUNTIME_TIMEOUT_SECONDS=45
CHAT_API_CALLBACK_TIMEOUT_SECONDS=10

# ---- Observability ----
ENABLE_OTEL=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=multi-agent-bench-agent-runtime
