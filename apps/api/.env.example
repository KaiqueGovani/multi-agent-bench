APP_ENV=local
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/multi_agent_bench
LOCAL_STORAGE_PATH=var/storage
STORAGE_PROVIDER=local
STORAGE_BUCKET=multi-agent-bench-poc
STORAGE_ENDPOINT_URL=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=us-east-1
STORAGE_ADDRESSING_STYLE=path
DEFAULT_CHANNEL=web_chat
DEFAULT_ARCHITECTURE_MODE=centralized_orchestration
RUNTIME_MODE=mock
API_KEY=
INTERNAL_SECRET=
AI_SERVICE_SECRET=
MAX_FILES_PER_MESSAGE=4
MAX_FILE_SIZE_BYTES=5242880
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
