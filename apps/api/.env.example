APP_ENV=local
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/multi_agent_bench
LOCAL_STORAGE_PATH=var/storage
STORAGE_PROVIDER=local
STORAGE_BUCKET=multi-agent-bench-poc
STORAGE_ENDPOINT_URL=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=us-east-1
STORAGE_ADDRESSING_STYLE=path
DEFAULT_CHANNEL=web_chat
DEFAULT_ARCHITECTURE_MODE=centralized_orchestration
DEFAULT_ARCHITECTURE_FAMILY=orchestration
DEFAULT_ARCHITECTURE_VERSION=poc
DEFAULT_ROUTING_STRATEGY=central_router
DEFAULT_MEMORY_STRATEGY=session_only
DEFAULT_TOOL_EXECUTOR_MODE=sequential
DEFAULT_REVIEW_POLICY_VERSION=mock-review-v1
DEFAULT_MODEL_PROVIDER=bedrock
DEFAULT_MODEL_NAME=us.anthropic.claude-haiku-4-5-20251001-v1:0
DEFAULT_MODEL_VERSION=2025-10-01
DEFAULT_PROMPT_BUNDLE_VERSION=mock-prompts-v1
DEFAULT_TOOLSET_VERSION=mock-tools-v1
DEFAULT_EXPERIMENT_ID=poc-local
RUNTIME_MODE=mock
MOCK_RUNTIME_STEP_DELAY_SECONDS=0.9
AI_RUNTIME_URL=
AI_RUNTIME_TIMEOUT_SECONDS=10
APP_BASE_URL=http://127.0.0.1:8000
RUNTIME_HISTORY_WINDOW_MESSAGES=8
API_KEY=
INTERNAL_SECRET=
AI_SERVICE_SECRET=
MAX_FILES_PER_MESSAGE=4
MAX_FILE_SIZE_BYTES=5242880
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
